# ---- PTT keys ---------------------------------------------------------------
# Key name (pynput): f1-f24, ctrl, alt, shift, space, tab, etc.
# Run detect_key.py to find the exact name for any key.
PTT_KEY=f15
PTT_KEY_OPTIMIZE=f16

# ---- Audio language ---------------------------------------------------------
# Whisper transcription language. Leave empty for auto-detect.
# Examples: en, es, fr, de, it, pt, zh, ja
WHISPER_LANG=es

# ---- Performance / accuracy -------------------------------------------------
# Model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=small

# CPU is the safest default. Use cuda only if your faster-whisper install supports it.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# 1 is fastest; 3-5 can improve accuracy but increases transcription time.
WHISPER_BEAM_SIZE=1

# 8 is a good default for modern CPUs. Lower it if the rest of Windows feels busy.
WHISPER_CPU_THREADS=8

# Open the mic only while the PTT key is held. Set true to keep the stream hot
# for lower startup latency at the cost of showing the OS mic-active indicator.
AUDIO_KEEP_OPEN=false

# If startup chooses the wrong mic, set AUDIO_DEVICE to a sounddevice device
# index/name after checking the log or querying devices.
AUDIO_DEVICE=
AUDIO_BLOCK_SIZE=512
AUDIO_LATENCY=low
AUDIO_TAIL_SECONDS=0.12
AUDIO_PAD_SECONDS=0.10
MIN_DURATION=0.35

# Startup runs with pythonw.exe, so diagnostics are written here.
VOICE_TYPER_LOG=voice_typer.log
VOICE_TYPER_PRIORITY=above_normal

# ---- Prompt optimizer (PTT_KEY_OPTIMIZE) ------------------------------------
# Provider: anthropic | openai | gemini | ollama
OPTIMIZE_PROVIDER=anthropic

# Cloud API keys — only the key for the selected provider is required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Local model (Ollama) — runs fully offline, no API key needed
# Install (Windows):  irm https://ollama.com/install.ps1 | iex
# Install (macOS):    brew install ollama
# Install (Linux):    curl -fsSL https://ollama.com/install.sh | sh
# Pull model: ollama pull phi4-mini
# OLLAMA_API_KEY can be any non-empty value (Ollama does not validate it)
OLLAMA_API_KEY=ollama
